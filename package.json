{
  "name": "kizuna",
  "version": "0.0.0",
  "private": true,
  "description": "A plugin-based local long-term memory MCP server for Claude Code, designed for cross-repository agent collaboration",
  "license": "MIT",
  "author": "Toshio Shiratori (@toshio-shiratori)",
  "repository": {
    "type": "git",
    "url": "https://github.com/toshio-shiratori/kizuna.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm build && pnpm -r test",
    "tsc": "pnpm -r exec tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "packageManager": "pnpm@11.0.3",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
