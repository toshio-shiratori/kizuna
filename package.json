{
  "name": "kizuna",
  "version": "0.1.0",
  "private": true,
  "description": "A plugin-based local long-term memory MCP server for Claude Code, designed for cross-repository agent collaboration",
  "license": "MIT",
  "author": "Toshio Shiratori (@toshio-shiratori)",
  "repository": {
    "type": "git",
    "url": "https://github.com/toshio-shiratori/kizuna.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm build && pnpm -r test",
    "tsc": "pnpm -r exec tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo",
    "prepare": "husky"
  },
  "packageManager": "pnpm@11.0.3",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
