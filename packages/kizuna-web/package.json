{
  "name": "@kizuna/web",
  "version": "0.1.0",
  "description": "Web UI for Kizuna - browser-based memory viewer",
  "license": "MIT",
  "author": "Toshio Shiratori (@toshio-shiratori)",
  "repository": {
    "type": "git",
    "url": "https://github.com/toshio-shiratori/kizuna.git",
    "directory": "packages/kizuna-web"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/server/index.ts",
      "import": "./dist/server/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/server/index.d.ts",
        "import": "./dist/server/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@kizuna/core": "workspace:*",
    "@kizuna/plugin-multi-repo-sharing": "workspace:*",
    "@kizuna/plugin-telepathy": "workspace:*",
    "hono": "^4.12.23",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
