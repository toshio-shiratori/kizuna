{
  "name": "@kizuna/plugin-openapi-awareness",
  "version": "0.1.0",
  "description": "Kizuna plugin that injects relevant OpenAPI endpoint information into context",
  "license": "MIT",
  "author": "Toshio Shiratori (@toshio-shiratori)",
  "repository": {
    "type": "git",
    "url": "https://github.com/toshio-shiratori/kizuna.git",
    "directory": "packages/plugin-openapi-awareness"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
